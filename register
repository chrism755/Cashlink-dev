<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Register - NETLINK AGENCIES</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
 .gradient-bg { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
</style>
</head>
<body class="gradient-bg min-h-screen flex items-center justify-center p-4">

<div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md">
  <h1 class="text-3xl font-bold text-center text-purple-700 mb-2">NETLINK AGENCIES</h1>
  <p class="text-center text-gray-600 mb-6">Create your account</p>
  
  <div id="alert"></div>
  
  <form id="registerForm" class="space-y-4">
    <input type="text" id="username" placeholder="Enter username" required 
      class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-purple-500 outline-none">
    
    <input type="email" id="email" placeholder="Enter valid Email" required 
      class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-purple-500 outline-none">
    
    <input type="tel" id="phone" placeholder="Enter phone number" required 
      class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-purple-500 outline-none">
    
    <input type="tel" id="whatsapp" placeholder="Enter WhatsApp number" required 
      class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-purple-500 outline-none">

    <select id="country" required 
      class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-purple-500 outline-none">
      <option value="">Select country</option>
      <option>Kenya</option><option>Uganda</option><option>Tanzania</option>
      <option>Nigeria</option><option>Ghana</option><option>Other</option>
    </select>

    <input type="password" id="password" placeholder="Enter password" required 
      class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-purple-500 outline-none">
    
    <input type="password" id="confirmPassword" placeholder="Confirm password" required 
      class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-purple-500 outline-none">

    <button type="submit" 
      class="w-full bg-purple-600 hover:bg-purple-700 text-white py-3 rounded-xl font-bold text-lg transition">
      Create Account
    </button>
  </form>
  
  <p class="text-center mt-4 text-gray-600">
    Already registered? 
    <a href="/login" class="text-purple-600 font-semibold">Log in</a>
  </p>
</div>

<script>
document.getElementById('registerForm').addEventListener('submit', function(e) {
  e.preventDefault();
  
  const password = document.getElementById('password').value;
  const confirmPassword = document.getElementById('confirmPassword').value;
  const alertBox = document.getElementById('alert');
  
  if (password !== confirmPassword) {
    alertBox.innerHTML = '<div class="bg-red-100 text-red-700 px-4 py-3 rounded-lg mb-4">Passwords do not match</div>';
    return;
  }
  
  alertBox.innerHTML = '<div class="bg-green-100 text-green-700 px-4 py-3 rounded-lg mb-4">Account created! Next step will be activation page.</div>';
  
  // For now, just show success. Next step we will redirect to /activation
  console.log({
    username: username.value,
    email: email.value,
    phone: phone.value,
    whatsapp: whatsapp.value,
    country: country.value,
    password: password
  });
});
</script>

</body>
</html>
